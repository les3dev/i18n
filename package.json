{
    "name": "@les3dev/i18n",
    "version": "0.1.4",
    "type": "module",
    "files": [
        "dist"
    ],
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./svelte": {
            "types": "./dist/svelte/svelte/index.svelte.d.ts",
            "svelte": "./dist/svelte/svelte/index.svelte.js",
            "default": "./dist/svelte/svelte/index.svelte.js"
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/les3dev/i18n.git"
    },
    "keywords": [
        "i18n",
        "internationalization",
        "svelte",
        "typescript",
        "type-safe"
    ],
    "author": "Les3Dev",
    "license": "MIT",
    "peerDependencies": {
        "svelte": ">=5.0.0"
    },
    "peerDependenciesMeta": {
        "svelte": {
            "optional": true
        }
    },
    "devDependencies": {
        "@sveltejs/adapter-auto": "^7.0.1",
        "@sveltejs/kit": "^2.55.0",
        "@sveltejs/package": "^2.0.0",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "svelte": "^5.0.0",
        "tsdown": "^0.22.3",
        "typescript": "^6.0.3"
    },
    "scripts": {
        "build": "svelte-kit sync && npm run build:ts && npm run build:svelte",
        "build:ts": "tsdown",
        "build:svelte": "svelte-package -o dist/svelte"
    }
}
